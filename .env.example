# Feishu Application Credentials
# Get these from Feishu Developer Console: https://open.feishu.cn/
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_ENCRYPT_KEY=  # Optional: Only needed if you enable encryption in developer console

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Redis Configuration (optional - for production token caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
